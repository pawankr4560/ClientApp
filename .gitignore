################################################################################
# This .gitignore file is optimized for .NET Core + Angular Projects
################################################################################

# --- Node / Angular Dependencies & Builds ---
node_modules/
.angular/
dist/
.sass-cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Environment Secrets & Local Configs ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
appsettings.Development.json

# --- Visual Studio & User Specific Files ---
.vs/
*.user
*.userosscache
*.sln.docstates
*.suo
*.vsidx
*.sqlite
*.sqlite-journal

# --- .NET Build Output Folders ---
bin/
obj/
[Dd]ebug/
[Rr]elease/

# --- Publish / Deployment Output ---
publish/
*.pubxml
*.pubxml.user
